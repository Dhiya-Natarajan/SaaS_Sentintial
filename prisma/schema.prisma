generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ApiMetric {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  service      String
  endpoint     String
  method       String
  statusCode   Int
  latencyMs    Int
  cost         Float    @default(0.0)
  requestSize  Int      @default(0)
  responseSize Int      @default(0)
}

model ServiceCredential {
  id        String   @id @default(uuid())
  service   String   @unique
  apiKey    String
  apiSecret String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FallbackConfig {
  id             String   @id @default(uuid())
  primaryService String   @unique
  fallbackService String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ModelDowngradeMapping {
  id          String   @id @default(uuid())
  service     String
  sourceModel String
  targetModel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([service, sourceModel])
}

model EnforcementLog {
  id                String          @id @default(uuid())
  timestamp         DateTime        @default(now())
  service           String
  routedService     String
  endpoint          String
  method            String
  reason            String          @default("NONE")
  severity          String
  action            String
  throttleMs        Int             @default(0)
  currentUsage      Int?
  anomalyThreshold  Float?
  anomalyMultiplier Float?
  details           String?
}
